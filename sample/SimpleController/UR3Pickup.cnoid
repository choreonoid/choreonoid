optional_plugins: [ PhysX, MuJoCo, ODE, AGXDynamics ]

items:
  id: 0
  name: "RootItem"
  plugin: Base
  class: RootItem
  is_builtin_item: true
  children:
    -
      id: 1
      name: "World"
      plugin: Body
      class: WorldItem
      is_checked: true
      data:
        collision_detection: false
        collision_detector: AISTCollisionDetector
        default_material_table_file: "${SHARE}/default/materials.yaml"
      children:
        -
          id: 2
          name: "UR3-2F85"
          plugin: Body
          class: BodyItem
          is_checked: true
          data:
            file: "${SHARE}/model/UniversalRobots/UR3-2F85.body"
            format: CHOREONOID-BODY
            root_translation: [ 0, 0, 0 ]
            root_rotation: [ 1, 0, 0, 0 ]
            joint_displacements: [
              0, -85.0288, 34.3775, -57.2958, -34.3775, -17.3784, 0, 0, 0, 0,
              0, 0 ]
            initial_root_translation: [ 0, 0, 0 ]
            initial_root_rotation: [ 1, 0, 0, 0 ]
            fix_root: true
            collision_detection: true
            lock_location: false
            scene_sensitive: true
          children:
            -
              id: 3
              name: "PickupController"
              plugin: Body
              class: SimpleControllerItem
              data:
                controller: "UniversalRobotPickupController"
                base_directory: "Controller directory"
                reloading: false
                export_symbols: false
        -
          id: 4
          name: "box3"
          plugin: Body
          class: BodyItem
          is_checked: true
          data:
            file: "${SHARE}/model/misc/box3.body"
            format: CHOREONOID-BODY
            root_translation: [ 0.5, 0, 0.035 ]
            root_rotation: [ 0, 0, 1, 90 ]
            initial_root_translation: [ 0.5, 0, 0.035 ]
            initial_root_rotation: [ 0, 0, 1, 90 ]
            fix_root: false
            collision_detection: true
            lock_location: false
            scene_sensitive: true
        -
          id: 5
          name: "box2"
          plugin: Body
          class: BodyItem
          is_checked: true
          data:
            file: "${SHARE}/model/misc/box2.body"
            format: CHOREONOID-BODY
            root_translation: [ 0, 0.4, -0.1 ]
            root_rotation: [ 1, 0, 0, 0 ]
            initial_root_translation: [ 0, 0.4, -0.1 ]
            initial_root_rotation: [ 1, 0, 0, 0 ]
            fix_root: true
            collision_detection: true
            lock_location: false
            scene_sensitive: true
        -
          id: 6
          name: "Floor"
          plugin: Body
          class: BodyItem
          is_checked: true
          data:
            file: "${SHARE}/model/misc/floor.body"
            format: CHOREONOID-BODY
            root_translation: [ 0, 0, -0.1 ]
            root_rotation: [ 1, 0, 0, 0 ]
            initial_root_translation: [ 0, 0, -0.1 ]
            initial_root_rotation: [ 1, 0, 0, 0 ]
            fix_root: true
            collision_detection: true
            lock_location: false
            scene_sensitive: true
        -
          id: 7
          name: "Simulators"
          plugin: Base
          class: FolderItem
          children:
            -
              id: 8
              name: "AISTSimulator"
              plugin: Body
              class: AISTSimulatorItem
              data:
                is_active_control_time_range_mode: true
            -
              id: 9
              name: "PhysXSimulator"
              plugin: PhysX
              class: PhysXSimulatorItem
              data:
                is_active_control_time_range_mode: true
            -
              id: 10
              name: "MuJoCoSimulator"
              plugin: MuJoCo
              class: MuJoCoSimulatorItem
              data:
                is_active_control_time_range_mode: true
            -
              id: 11
              name: "ODESimulator"
              plugin: ODE
              class: ODESimulatorItem
              data:
                is_active_control_time_range_mode: true
                step_mode: "Big matrix"
                add_joint_axis_inertia_to_link_inertia: true
            -
              id: 12
              name: "AGXSimulator"
              plugin: AGXDynamics
              class: AGXSimulatorItem
              data:
                is_active_control_time_range_mode: true
views:
  -
    id: 4
    plugin: Base
    class: SceneView
    mounted: true
    state:
      floor_grid: false
      field_of_view: 39.981
      cameras:
        -
          camera: [ System, Perspective ]
          is_current: true
          eye: [ 0.986076758, 1.25939447, 0.509271744 ]
          direction: [ -0.654273041, -0.720663658, -0.22928297 ]
          up: [ -0.154119437, -0.169758297, 0.97335981 ]
