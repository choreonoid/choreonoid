optional_plugins: [ PhysX, MuJoCo, ODE, AGXDynamics ]

items:
  id: 0
  name: "RootItem"
  plugin: Base
  class: RootItem
  is_builtin_item: true
  children:
    -
      id: 1
      name: "World"
      plugin: Body
      class: WorldItem
      is_checked: true
      data:
        collision_detection: false
        collision_detector: AISTCollisionDetector
        default_material_table_file: "${SHARE}/default/materials.yaml"
      children:
        -
          id: 2
          name: "Floor"
          plugin: Body
          class: BodyItem
          is_checked: true
          data:
            file: "${SHARE}/model/misc/floor.body"
            format: CHOREONOID-BODY
            root_translation: [ 0, 0, -0.1 ]
            root_rotation: [ 1, 0, 0, 0 ]
            initial_root_translation: [ 0, 0, -0.1 ]
            initial_root_rotation: [ 1, 0, 0, 0 ]
            fix_root: true
            collision_detection: true
            lock_location: false
            scene_sensitive: true
        -
          id: 3
          name: "Blocks"
          plugin: Base
          class: FolderItem
          children:
            -
              id: 4
              name: "box2"
              plugin: Body
              class: BodyItem
              is_checked: true
              data:
                file: "${SHARE}/model/misc/box2.body"
                format: CHOREONOID-BODY
                root_translation: [ 0, 0, 0.15 ]
                root_rotation: [ 1, 0, 0, 0 ]
                initial_root_translation: [ 0, 0, 0.15 ]
                initial_root_rotation: [ 1, 0, 0, 0 ]
                fix_root: false
                collision_detection: true
                lock_location: false
                scene_sensitive: true
            -
              id: 5
              name: "box2"
              plugin: Body
              class: BodyItem
              is_checked: true
              data:
                file: "${SHARE}/model/misc/box2.body"
                format: CHOREONOID-BODY
                root_translation: [ 0, 0.3, 0.15 ]
                root_rotation: [ 1, 0, 0, 0 ]
                initial_root_translation: [ 0, 0.3, 0.15 ]
                initial_root_rotation: [ 1, 0, 0, 0 ]
                fix_root: false
                collision_detection: true
                lock_location: false
                scene_sensitive: true
