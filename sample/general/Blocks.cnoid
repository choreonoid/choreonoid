          id: 25
          name: "Simulators"
          plugin: Base
          class: FolderItem
          children:
            -
              id: 26
              name: "AISTSimulator"
              plugin: Body
              class: AISTSimulatorItem
              data:
                time_range_mode: timebar
                num_collision_detection_threads: 4
            -
              id: 27
              name: "PhysXSimulator"
              plugin: PhysX
              class: PhysXSimulatorItem
              data:
                time_range_mode: timebar
                num_threads: 1
                sdf_construction_threads: 1
            -
              id: 28
              name: "MuJoCoSimulator"
              plugin: MuJoCo
              class: MuJoCoSimulatorItem
              data:
                time_range_mode: timebar
            -
              id: 29
              name: "ODESimulator"
              plugin: ODE
              class: ODESimulatorItem
              data:
                time_range_mode: timebar
            -
              id: 30
              name: "AGXSimulator"
              plugin: AGXDynamics
              class: AGXSimulatorItem
              data:
                time_range_mode: timebar
                NumThreads: 1
views:
  -
    id: 2
    plugin: Base
    class: ItemTreeView
    mounted: true
    state:
      expanded: [ 1, 25 ]
  -
    id: 4
    plugin: Base
    class: SceneView
    mounted: true
    state:
      floor_grid: false
      cameras:
        -
          camera: [ System, Perspective ]
          is_current: true
          eye: [ 4.05226487, 2.79696515, 1.22373011 ]
          direction: [ -0.900894541, -0.428144959, -0.0712805792 ]
          up: [ -0.0643800479, -0.0305962482, 0.997456304 ]
toolbars:
  "TimeBar":
    min_time: 0
    max_time: 10
