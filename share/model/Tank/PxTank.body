            rotation: [ 0, 1, 0, 12 ]
            elements: &OUTER_PLATE3
              Shape:
                geometry: { type: Box, size: [ 0.067, 0.01, 0.02 ] }
          -
            type: Transform
            translation: [ 0.24, 0.105, -0.043 ]
            rotation: [ 0, 1, 0, -12 ]
            elements: *OUTER_PLATE3
          -
            type: Transform
            translation: [ -0.2425, 0.105, 0.0 ]
            elements: *OUTER_PLATE2
          -
            type: Transform
            translation: [ -0.24, 0.105, 0.043 ]
            rotation: [ 0, 1, 0, -12 ]
            elements: *OUTER_PLATE3
          -
            type: Transform
