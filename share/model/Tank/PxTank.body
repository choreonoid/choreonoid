            rotation: [ 0, 1, 0, 12 ]
            elements: *OUTER_PLATE3
  -
    name: WHEEL_L0
    parent: TRACK_L
    translation: [ 0.2503, 0.055, 0 ]
    jointType: revolute
    jointAxis: Y
    centerOfMass: [ 0, 0, 0 ]
    mass: 1.0
    inertia: [
      0.02, 0,    0,
      0,    0.02, 0,
      0,    0,    0.02 ]
    material: TankWheel
    elements:
